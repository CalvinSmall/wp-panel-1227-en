name = "wp-panel-stats"
main = "index.js"
compatibility_date = "2025-01-01"

# Worker receives panel anonymous heartbeat reports and provides public statistics API.
# Before deployment, create the KV namespace first:
#   npx wrangler kv namespace create "STATS_KV"
# Then fill in the output id in the double quotes below.

[[kv_namespaces]]
binding = "STATS_KV"
id = "YOUR_KV_NAMESPACE_ID"
preview_id = "YOUR_KV_NAMESPACE_ID"
